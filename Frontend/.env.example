# PayShield Frontend — Environment Variables
# Copy this file to .env and fill in your values

# ── Web3 ──────────────────────────────────────────────────────────────
# No env vars needed for MetaMask (it injects window.ethereum automatically)

# ── Pinata IPFS ───────────────────────────────────────────────────────
# Get your JWT from https://app.pinata.cloud/developers/api-keys
VITE_PINATA_JWT=your_pinata_jwt_here

# ── Backend API ───────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5000/api

# ── Deployed Contract Addresses ───────────────────────────────────────
# Fill these in after running: npm run deploy:sepolia (from Smartcontract/)
VITE_ESCROW_ADDRESS=0x...
VITE_ARBITRATOR_ADDRESS=0x...

# ── Network ───────────────────────────────────────────────────────────
VITE_CHAIN_ID=11155111
VITE_NETWORK_NAME=Sepolia
